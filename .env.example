# =======================================================
# VARIABLES D'ENVIRONNEMENT — CIV-EYE MODULE 1 URBANISME
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne JAMAIS commiter .env dans le dépôt !
# =======================================================

# ----------------- Configuration Core Django -----------------
# Clé secrète Django — OBLIGATOIRE en production.
# Générer via : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY="django-insecure-replace-this-with-a-very-long-and-secure-key"

# True = Mode Dev (stack traces visibles) / False = Mode Prod
DEBUG=True

# Hôtes autorisés — OBLIGATOIRE si DEBUG=False
ALLOWED_HOSTS="127.0.0.1,localhost"

# ----------------- Base de Données -----------------
# PostGIS requis pour les requêtes spatiales (ST_Contains, ST_DWithin)
# Format : postgis://user:password@host:port/dbname
DATABASE_URL=postgis://postgres:password@localhost:5432/siade_db

# ----------------- Sentinel Hub (optionnel) -----------------
# Plan gratuit : 30 000 unités/mois. Le pipeline fonctionne sans (fallback CDSE).
# Obtenir via : apps.sentinel-hub.com → OAuth clients
SENTINEL_HUB_CLIENT_ID=""
SENTINEL_HUB_CLIENT_SECRET=""

# ----------------- CDSE Copernicus (source principale gratuite) -----------------
# Token nécessaire pour le téléchargement de gros rasters (> 100 Mo).
# Petites requêtes STAC : pas de token requis.
# Obtenir via : dataspace.copernicus.eu → Mon compte → Tokens
CDSE_TOKEN=""

# ----------------- Google Earth Engine -----------------
# Requis pour : Google Open Buildings V3, Temporal V1, composites multi-temporels
# 1. console.cloud.google.com → créer un projet → activer Earth Engine API
# 2. Terminal : earthengine authenticate (une seule fois)
GEE_PROJECT_ID=""

# ----------------- Google Maps (optionnel) -----------------
GOOGLE_MAPS_API_KEY=""

# ----------------- Microsoft Planetary Computer (obsolète) -----------------
# Remplacé par Google Open Buildings V3. Laisser vide.
MICROSOFT_PC_API_KEY=""

# ----------------- HuggingFace (scoring local uniquement) -----------------
# Le mode cloud HuggingFace est désactivé (modèles inadaptés).
# Le scoring local (_local_ai_score) fonctionne SANS token.
# Laisser vide sauf besoin futur.
HUGGINGFACE_TOKEN=""

# ----------------- SAR Sentinel-1 via ASF Alaska (v2, pas encore implémenté) ---------
# Gratuit — compte NASA Earthdata : urs.earthdata.nasa.gov
# Utilisé pour la surveillance en saison des pluies (nuages > 50%)
NASA_EARTHDATA_USERNAME=""
NASA_EARTHDATA_PASSWORD=""

# ----------------- Services Asynchrones (optionnel) -----------------
# Redis pour Celery (file d'attente IA)
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# ----------------- CORS (M18 — si frontend séparé) -----------------
# En production, lister les origines autorisées (séparées par virgule)
# CORS_ALLOWED_ORIGINS="https://civ-eye.ci,https://admin.civ-eye.ci"

# ----------------- Logging & Télémétrie (optionnel) -----------------
SENTRY_DSN=""
